<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppmeucombustivel.MainPage"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label Text="Cálculo de Combustível"
                   TextColor="Blue"
                   FontSize="30"
                   HorizontalOptions="Center"
                   Margin="10"/>

            <Image
                Source="car.jpg"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label Text="Marca do Veículo:"
                   TextColor="Blue"/>
            <Entry x:Name="txt_marca"
                   Placeholder="Ex: Honda"/>

            <Label Text="Modelo do Veículo:"
                   TextColor="Blue"/>
            <Entry x:Name="txt_modelo"
                   Placeholder="Ex: Civic"/>

            <Label Text="Preço do Etanol:"
                   TextColor="Blue"/>
            <Entry x:Name="txt_etanol" Placeholder="R$ "
                   Keyboard="Numeric"/>

            <Label Text="Preço da Gasolina:"
                   TextColor="Blue"/>
            <Entry x:Name="txt_gasolina" Placeholder="R$ "
                   Keyboard="Numeric"/>

            <Button Text="Qual compensa mais?" Clicked="Button_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
